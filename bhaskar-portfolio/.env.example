# .env.example
# -----------------------------------------------------------------------
# Copy this file to ".env" and fill in your real Supabase project values.
# Get these from: Supabase Dashboard -> Project Settings -> API
#
#   VITE_SUPABASE_URL      -> "Project URL"
#   VITE_SUPABASE_ANON_KEY -> "anon public" key
#
# NOTE: Vite only exposes env vars to the browser if they are prefixed
# with VITE_. Never put your Supabase "service_role" secret key here —
# that one only belongs on the server side (Edge Functions).
# -----------------------------------------------------------------------
VITE_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
